<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campushub.user.mapper.UserVerificationMapper">

    <resultMap id="UserVerificationResultMap" type="com.campushub.user.entity.UserVerification">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="reviewerId" column="reviewer_id"/>
        <result property="realName" column="real_name"/>
        <result property="studentCardImage" column="student_card_image"/>
        <result property="status" column="status"/>
        <result property="rejectReason" column="reject_reason"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="UserVerificationColumns">
        id,
        user_id,
        reviewer_id,
        real_name,
        student_card_image,
        status,
        reject_reason,
        create_time,
        update_time
    </sql>

    <select id="selectLatestByUserId" resultMap="UserVerificationResultMap">
        SELECT
        <include refid="UserVerificationColumns"/>
        FROM t_user_verification
        WHERE user_id = #{userId}
        ORDER BY create_time DESC, id DESC
        LIMIT 1
    </select>

    <select id="selectPendingByUserId" resultMap="UserVerificationResultMap">
        SELECT
        <include refid="UserVerificationColumns"/>
        FROM t_user_verification
        WHERE user_id = #{userId}
          AND status = 0
        ORDER BY create_time DESC, id DESC
        LIMIT 1
    </select>

    <select id="selectPendingList" resultMap="UserVerificationResultMap">
        SELECT
        <include refid="UserVerificationColumns"/>
        FROM t_user_verification
        WHERE status = 0
        ORDER BY create_time ASC, id ASC
    </select>
</mapper>

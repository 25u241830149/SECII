<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campushub.user.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.campushub.user.entity.User">
        <id property="id" column="id"/>
        <result property="studentId" column="student_id"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="nickname" column="nickname"/>
        <result property="realName" column="real_name"/>
        <result property="department" column="department"/>
        <result property="avatarUrl" column="avatar_url"/>
        <result property="role" column="role"/>
        <result property="creditScore" column="credit_score"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="isDeleted" column="is_deleted"/>
    </resultMap>

    <sql id="UserColumns">
        id,
        student_id,
        password,
        email,
        phone,
        nickname,
        real_name,
        department,
        avatar_url,
        role,
        credit_score,
        status,
        create_time,
        update_time,
        is_deleted
    </sql>

    <select id="selectActiveById" resultMap="UserResultMap">
        SELECT
        <include refid="UserColumns"/>
        FROM u_user
        WHERE id = #{id}
          AND is_deleted = false
        LIMIT 1
    </select>

    <select id="selectActiveByStudentId" resultMap="UserResultMap">
        SELECT
        <include refid="UserColumns"/>
        FROM u_user
        WHERE student_id = #{studentId}
          AND is_deleted = false
        LIMIT 1
    </select>

    <select id="existsByStudentId" resultType="int">
        SELECT CASE WHEN EXISTS (
            SELECT 1
            FROM u_user
            WHERE student_id = #{studentId}
              AND is_deleted = false
        ) THEN 1 ELSE 0 END
    </select>
</mapper>
